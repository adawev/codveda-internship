# =========================
# Backend
# =========================
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

DB_URL=jdbc:postgresql://localhost:5432/codveda
DB_USERNAME=postgres
DB_PASSWORD=postgres

APP_JWT_SECRET=replace-with-a-long-random-secret
APP_JWT_ACCESS_EXPIRATION_MS=900000
APP_JWT_REFRESH_EXPIRATION_MS=604800000

APP_AUTH_REFRESH_COOKIE_NAME=refresh_token
APP_AUTH_REFRESH_COOKIE_SECURE=false

APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

APP_ADMIN_PASSWORD=ChangeMe123!

# Optional WebSocket broker relay (disabled by default)
APP_WS_RELAY_ENABLED=false
APP_WS_RELAY_HOST=localhost
APP_WS_RELAY_PORT=61613
APP_WS_RELAY_CLIENT_LOGIN=guest
APP_WS_RELAY_CLIENT_PASSCODE=guest
APP_WS_RELAY_SYSTEM_LOGIN=guest
APP_WS_RELAY_SYSTEM_PASSCODE=guest

# =========================
# Frontend
# =========================
REACT_APP_API_BASE_URL=http://localhost:8080
