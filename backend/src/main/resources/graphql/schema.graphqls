scalar BigDecimal

type Query {
  getProducts(page: Int!, size: Int!): ProductPage!
  getUserOrders: [Order!]!
}

type Mutation {
  createOrder(input: CreateOrderInput!): Order!
  updateProduct(id: ID!, input: UpdateProductInput!): Product!
}

type ProductPage {
  content: [Product!]!
  page: Int!
  size: Int!
  totalElements: Int!
  totalPages: Int!
}

type Product {
  id: ID!
  name: String!
  description: String
  price: BigDecimal!
  stock: Int!
  imageUrl: String
}

type Order {
  id: ID!
  totalPrice: BigDecimal!
  shippingAddress: String!
  paymentMethod: String!
  totalAmount: BigDecimal!
  status: String!
  createdAt: String!
  items: [OrderItem!]!
}

type OrderItem {
  id: ID!
  productId: ID!
  productName: String!
  quantity: Int!
  price: BigDecimal!
}

input UpdateProductInput {
  name: String
  description: String
  price: BigDecimal
  stock: Int
  imageUrl: String
}

input CreateOrderInput {
  shippingAddress: String!
  paymentMethod: String!
  totalAmount: BigDecimal!
}
